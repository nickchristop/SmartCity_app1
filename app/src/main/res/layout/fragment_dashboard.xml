<?xml version="1.0" encoding="utf-8"?>
<!-- Hazards fragment: lists active and past community reports -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_gray">

    <!-- Screen title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_hazards"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"/>

    <!-- Tab strip: Active / Past -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout_hazards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:tabTextColor="@color/primary_blue"
        app:tabSelectedTextColor="@color/primary_blue"
        app:tabIndicatorColor="@color/primary_blue"
        android:layout_marginBottom="4dp"/>

    <!-- RecyclerView shows the active or past list depending on selected tab -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_hazards"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"/>

    <!-- Shown when the selected list is empty -->
    <TextView
        android:id="@+id/tv_hazards_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/empty_hazards"
        android:textColor="#9E9E9E"
        android:textSize="16sp"
        android:visibility="gone"/>

</LinearLayout>

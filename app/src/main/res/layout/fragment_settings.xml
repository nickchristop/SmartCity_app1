<?xml version="1.0" encoding="utf-8"?>
<!-- Settings: Theme + Language + City Contact + GPS Mock -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Appearance section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_appearance"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="12dp"/>

        <RadioGroup
            android:id="@+id/rg_theme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp">
            <RadioButton
                android:id="@+id/rb_theme_light"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_light_mode"
                android:textSize="16sp"/>
            <RadioButton
                android:id="@+id/rb_theme_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_dark_mode"
                android:textSize="16sp"/>
        </RadioGroup>

        <!-- Language section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_language"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="12dp"/>

        <RadioGroup
            android:id="@+id/rg_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp">
            <RadioButton
                android:id="@+id/rb_lang_en"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_english"
                android:textSize="16sp"/>
            <RadioButton
                android:id="@+id/rb_lang_el"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_greek"
                android:textSize="16sp"/>
        </RadioGroup>

        <!-- GPS Settings section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GPS Settings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_gps_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:text="Device GPS Settings"
            app:icon="@android:drawable/ic_menu_mylocation" />

        <!-- City Contact section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_contact"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_contact_phone"
            android:textSize="18sp"
            android:textColor="#1565C0"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_contact_info"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
